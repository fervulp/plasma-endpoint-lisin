#!/usr/bin/env bash
# Расширение доступа для агента LiSin. ЗАПУСКАТЬ ОТ ROOT:
#     sudo packaging/lisin-grant-access <пользователь>
#
# Что делает и ЗАЧЕМ (каждый пункт закрывает конкретную дыру в данных):
#   1) правила auditd на exec/файлы/логины  → заполнит process_*, file_*,
#      source_ip у событий (сейчас их даёт только поллинг, короткие процессы
#      теряются);
#   2) группа для чтения /var/log/audit    → полный аудит вместо того куска,
#      что пролезает через journald;
#   3) systemd-юнит                        → агент собирает постоянно, а не
#      пока открыто окно.
# Ничего не делает молча: перед каждым шагом печатает, что именно меняет.
set -euo pipefail
USER_NAME="${1:-}"
[ -z "$USER_NAME" ] && { echo "использование: $0 <пользователь>"; exit 1; }
[ "$(id -u)" -eq 0 ] || { echo "нужен root: sudo $0 $USER_NAME"; exit 1; }

RULES=/etc/audit/rules.d/lisin.rules
echo "==> 1/3 правила auditd -> $RULES"
cat > "$RULES" <<'RULES'
## LiSin: запуск процессов (даёт execve с аргументами и родителем)
-a always,exit -F arch=b64 -S execve,execveat -k lisin_exec
## LiSin: изменение ключевых конфигов и путей автозапуска
-w /etc/passwd    -p wa -k lisin_identity
-w /etc/shadow    -p wa -k lisin_identity
-w /etc/sudoers   -p wa -k lisin_identity
-w /etc/sudoers.d -p wa -k lisin_identity
-w /etc/cron.d    -p wa -k lisin_persist
-w /etc/systemd/system -p wa -k lisin_persist
-w /etc/ld.so.preload  -p wa -k lisin_persist
## LiSin: модули ядра
-a always,exit -F arch=b64 -S init_module,finit_module,delete_module -k lisin_module
RULES
augenrules --load 2>/dev/null || service auditd restart 2>/dev/null || true
echo "    загружено правил: $(auditctl -l | wc -l)"

echo "==> 2/3 доступ на чтение журнала аудита пользователю $USER_NAME"
if getent group audit >/dev/null; then
  usermod -aG audit "$USER_NAME"
  # log_group=audit заставляет auditd класть логи с группой audit
  if grep -q '^log_group' /etc/audit/auditd.conf; then
    sed -i 's/^log_group.*/log_group = audit/' /etc/audit/auditd.conf
  else
    echo "log_group = audit" >> /etc/audit/auditd.conf
  fi
  chgrp audit /var/log/audit /var/log/audit/* 2>/dev/null || true
  chmod 0750 /var/log/audit 2>/dev/null || true
  chmod 0640 /var/log/audit/audit.log 2>/dev/null || true
  echo "    $USER_NAME добавлен в группу audit (нужен перелогин)"
else
  echo "    группы audit нет — пропускаю"
fi

echo "==> 3/3 systemd-юнит (сбор идёт постоянно, не только при открытом окне)"
cat > /etc/systemd/system/lisin-agent.service <<UNIT
[Unit]
Description=LiSin EDR agent (collector)
After=network.target auditd.service

[Service]
Type=simple
User=$USER_NAME
WorkingDirectory=$(pwd)
Environment=PYTHONNOUSERSITE=1
ExecStart=/usr/bin/python3 $(pwd)/lisin_app.py --headless
Restart=on-failure

[Install]
WantedBy=multi-user.target
UNIT
systemctl daemon-reload
echo "    юнит создан. Включить: systemctl enable --now lisin-agent"
echo
echo "ГОТОВО. Перелогиньтесь, чтобы группа audit применилась, и проверьте:"
echo "  auditctl -l | head        # правила на месте"
echo "  head -1 /var/log/audit/audit.log   # журнал читается"
