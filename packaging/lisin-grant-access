#!/usr/bin/env bash
# Access extension for the LiSin agent. RUN AS ROOT:
#     sudo packaging/lisin-grant-access <user>
#
# What it does and WHY (each item closes a specific gap in the data):
#   1) auditd rules on exec/files/logins  -> fills process_*, file_*,
#      source_ip on events (right now only polling provides them, and short
#      lived processes are lost);
#   2) a group that may read /var/log/audit -> the full audit instead of the
#      slice that leaks through journald;
#   3) a systemd unit                      -> the agent collects all the time,
#      not only while the window is open.
# It does nothing silently: before every step it prints what exactly it changes.
set -euo pipefail
USER_NAME="${1:-}"
[ -z "$USER_NAME" ] && { echo "usage: $0 <user>"; exit 1; }
[ "$(id -u)" -eq 0 ] || { echo "root required: sudo $0 $USER_NAME"; exit 1; }

RULES=/etc/audit/rules.d/lisin.rules
echo "==> 1/3 auditd rules -> $RULES"
cat > "$RULES" <<'RULES'
## LiSin: process execution (gives execve with arguments and the parent)
-a always,exit -F arch=b64 -S execve,execveat -k lisin_exec
## LiSin: changes to key configuration files and autostart paths
-w /etc/passwd    -p wa -k lisin_identity
-w /etc/shadow    -p wa -k lisin_identity
-w /etc/sudoers   -p wa -k lisin_identity
-w /etc/sudoers.d -p wa -k lisin_identity
-w /etc/cron.d    -p wa -k lisin_persist
-w /etc/systemd/system -p wa -k lisin_persist
-w /etc/ld.so.preload  -p wa -k lisin_persist
## LiSin: kernel modules
-a always,exit -F arch=b64 -S init_module,finit_module,delete_module -k lisin_module
RULES
augenrules --load 2>/dev/null || service auditd restart 2>/dev/null || true
echo "    rules loaded: $(auditctl -l | wc -l)"

echo "==> 2/3 read access to the audit log for $USER_NAME"
if getent group audit >/dev/null; then
  usermod -aG audit "$USER_NAME"
  # log_group=audit makes auditd write the logs with the audit group
  if grep -q '^log_group' /etc/audit/auditd.conf; then
    sed -i 's/^log_group.*/log_group = audit/' /etc/audit/auditd.conf
  else
    echo "log_group = audit" >> /etc/audit/auditd.conf
  fi
  chgrp audit /var/log/audit /var/log/audit/* 2>/dev/null || true
  chmod 0750 /var/log/audit 2>/dev/null || true
  chmod 0640 /var/log/audit/audit.log 2>/dev/null || true
  echo "    $USER_NAME added to the audit group (a re-login is needed)"
else
  echo "    there is no audit group - skipping"
fi

echo "==> 3/3 systemd unit (collection runs all the time, not only while the window is open)"
cat > /etc/systemd/system/lisin-agent.service <<UNIT
[Unit]
Description=LiSin EDR agent (collector)
After=network.target auditd.service

[Service]
Type=simple
User=$USER_NAME
WorkingDirectory=$(pwd)
Environment=PYTHONNOUSERSITE=1
ExecStart=/usr/bin/python3 $(pwd)/lisin_app.py --headless
Restart=on-failure

[Install]
WantedBy=multi-user.target
UNIT
systemctl daemon-reload
echo "    unit created. Enable it with: systemctl enable --now lisin-agent"

echo "==> 4/4 eBPF process collector (catches EVERY execve, the short-lived ones polling misses)"
SPOOL="/home/$USER_NAME/.local/share/lisin/ebpf-exec.log"
if command -v bpftrace >/dev/null 2>&1; then
  install -D -m 0755 "$(pwd)/packaging/lisin-ebpf-exec.bt" /usr/local/lib/lisin/lisin-ebpf-exec.bt
  # the spool lives in the user's home so the (user-run) input can read it;
  # bpftrace runs as root and APPENDS to it (append keeps the file's owner)
  install -d -o "$USER_NAME" -m 0755 "/home/$USER_NAME/.local/share/lisin"
  install -o "$USER_NAME" -m 0640 /dev/null "$SPOOL"
  cat > /etc/systemd/system/lisin-ebpf.service <<UNIT
[Unit]
Description=LiSin eBPF process collector (execve/exit)
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/bpftrace -q -B line -o $SPOOL /usr/local/lib/lisin/lisin-ebpf-exec.bt
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
UNIT
  # keep the spool bounded - the input only reads the tail, dedup handles overlap
  cat > /etc/logrotate.d/lisin-ebpf <<ROT
$SPOOL {
    size 20M
    rotate 1
    missingok
    notifempty
    copytruncate
}
ROT
  systemctl daemon-reload
  echo "    unit created. Start it with: systemctl enable --now lisin-ebpf"
  echo "    (eBPF needs no re-login; events appear within one input interval)"
else
  echo "    bpftrace is not installed - skipping. Install it with: dnf install bpftrace"
fi
echo
echo "DONE. Log out and back in so that the audit group applies, then check:"
echo "  auditctl -l | head        # the rules are in place"
echo "  head -1 /var/log/audit/audit.log   # the log is readable"
echo "  systemctl status lisin-ebpf        # the eBPF collector is running"
